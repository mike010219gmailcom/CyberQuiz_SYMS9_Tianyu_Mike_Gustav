@page "/"

@using Microsoft.AspNetCore.Components

<PageTitle>CyberQuiz</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4 mb-3">CyberQuiz</h1>
            <p class="lead mb-4">Train. Secure. Evolve. Test your cybersecurity knowledge and follow your progression.</p>

            <div class="d-flex justify-content-center gap-2">
                <a class="btn btn-primary btn-lg" href="/login">Logga in</a>
                <a class="btn btn-outline-secondary btn-lg" href="/register">Registrera</a>
            </div>

            <hr class="my-5" />

            <p class="text-muted">Endast välkomstsida, registrering och login är tillgängliga utan inloggning.</p>
        </div>
    </div>
</div>

@page "/"

@using Microsoft.AspNetCore.Components

<PageTitle>CyberQuiz</PageTitle>

<div class="home-container">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="card home-card shadow-lg">
                    <div class="card-body text-center p-5">
                        <!-- Title -->
                        <h1 class="home-title mb-3">
                            <span class="gradient-text">CyberQuiz</span>
                        </h1>

                        <!-- Subtitle -->
                        <p class="lead text-muted mb-4">
                            Sharpen your cyber instincts. One question at a time.
                        </p>

                        <!-- Buttons -->
                        <div class="d-flex flex-column flex-sm-row justify-content-center gap-3 mb-4">
                            <a class="btn btn-custom-primary btn-lg" href="/Login">
                                Logga in
                                <span class="arrow ms-2">→</span>
                            </a>
                            <a class="btn btn-custom-outline btn-lg" href="/register">
                                Registrera
                            </a>
                        </div>

                        <!-- Footer -->
                        <hr class="my-4" />
                        <p class="text-muted small mb-0">© 2026 CyberQuiz. All Rights Reserved.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

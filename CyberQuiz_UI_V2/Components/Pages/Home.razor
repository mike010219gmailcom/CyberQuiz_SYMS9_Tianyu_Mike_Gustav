@page "/"

@using Microsoft.AspNetCore.Components

<PageTitle>CyberQuiz</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4 mb-3" style="font-family: 'Orbitron', sans-serif; font-weight: 900; letter-spacing: 2px; color: #9d4edd;">

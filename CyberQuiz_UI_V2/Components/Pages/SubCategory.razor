@page "/subcategory/{SubCategoryId:int}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Subkategori</PageTitle>

<div class="container py-4">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Laddar...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-warning">
            <strong>Info:</strong> @errorMessage
            <div class="mt-3">
                <a href="/start" class="btn btn-secondary">← Tillbaka till kategorier</a>
            </div>
        </div>
    }
    else if (subCategory != null)
    {
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <!--Bbreadcrumb navi -->
                <nav aria-label="breadcrumb" class="mb-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/start">Kategorier</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@subCategory.Name</li>
                    </ol>
                </nav>

                <!-- Subkategori Card -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body text-center py-5">
                        <div class="mb-3">
                            <span class="badge bg-success fs-3">🔓</span>
                        </div>

                        <h2 class="mb-3">@subCategory.Name</h2>
                        
                        <p class="lead mb-4">
                            <span class="badge bg-primary fs-5">@subCategory.QuestionCount frågor</span>
                        </p>

                        @if (subCategory.IsLocked)
                        {
                            <div class="alert alert-warning">
                                <strong>Denna subkategori är låst.</strong><br />
                                Du måste nå minst 80% i föregående subkategori för att låsa upp.
                            </div>
                            <a href="/start" class="btn btn-secondary">← Tillbaka till kategorier</a>
                        }
                        else
                        {
                            @if (subCategory.IsLocked)
                            {
                                <div class="alert alert-warning">
                                    <strong>Denna subkategori är låst.</strong><br />
                                    Du måste nå minst 80% i föregående subkategori för att låsa upp.
                                </div>
                                <a href="/start" class="btn btn-secondary">← Tillbaka till kategorier</a>
                            }
                            else
                            {
                                <button class="btn btn-primary btn-lg" @onclick="StartQuiz">
                                    Starta quiz →
                                </button>
                                <div class="mt-3">
                                    <a href="/start" class="btn btn-link">← Tillbaka till kategorier</a>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Tidigare resultat (om det finns) -->
                @if (accuracy.HasValue)
                {
                    <div class="card shadow-sm">
                        <div class="card-header">
                            <h5 class="mb-0">Din tidigare prestation</h5>
                        </div>
                        <div class="card-body text-center">
                            <div class="display-4 mb-2">
                                <span class="@GetAccuracyColorClass(accuracy.Value)">@accuracy.Value%</span>
                            </div>
                            <p class="text-muted mb-0">Total accuracy för denna subkategori</p>
                            
                            @if (accuracy.Value >= 80)
                            {
                                <div class="alert alert-success mt-3 mb-0">
                                    <strong>Bra jobbat!</strong> Du har nått 80%-spärren.
                                </div>
                            }
                            else if (accuracy.Value > 0)
                            {
                                <div class="alert alert-info mt-3 mb-0">
                                    Du kan göra om quizet för att förbättra ditt resultat.
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int SubCategoryId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private SubCategoryDetailModel? subCategory;
    private int? accuracy;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubCategoryAsync();
    }

    private async Task LoadSubCategoryAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            // Använd befintlig endpoint från QuizController
            var resp = await Http.GetAsync($"/api/quiz/start/{SubCategoryId}");
            if (resp.IsSuccessStatusCode)
            {
                var quizData = await resp.Content.ReadFromJsonAsync<QuizDataModel>();

                if (quizData?.SubCategory != null)
                {
                    subCategory = new SubCategoryDetailModel
                    {
                        Id = quizData.SubCategory.Id,
                        Name = quizData.SubCategory.Name,
                        QuestionCount = quizData.Questions?.Count ?? 0
                    };
                }
                else
                {
                    errorMessage = "Subkategorin hittades inte.";
                }
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                errorMessage = "Subkategorin hittades inte.";
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Du måste vara inloggad.";
            }
            else
            {
                errorMessage = $"Kunde inte hämta data (status: {resp.StatusCode}).";
            }

            // Försök hämta tidigare resultat från profil (valfritt)
            if (subCategory != null)
            {
                await TryLoadAccuracyAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte nå servern. ({ex.Message})";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task TryLoadAccuracyAsync()
    {
        try
        {
            var resp = await Http.GetAsync("/api/profile");
            if (resp.IsSuccessStatusCode)
            {
                var profile = await resp.Content.ReadFromJsonAsync<ProfileDataModel>();
                var subResult = profile?.PerSubCategory?.FirstOrDefault(s => s.SubCategoryId == SubCategoryId);
                if (subResult != null)
                {
                    accuracy = subResult.AccuracyPercent;
                }
            }
        }
        catch
        {
            // Ignore - tidigare resultat är valfritt
        }
    }

    private void StartQuiz()
    {
        Navigation.NavigateTo($"/quiz/{SubCategoryId}");
    }

    private string GetAccuracyColorClass(int percent)
    {
        if (percent >= 80) return "text-success";
        if (percent >= 50) return "text-warning";
        return "text-danger";
    }

    private class QuizDataModel
    {
        public SubCategoryInfoModel? SubCategory { get; set; }
        public List<QuestionModel>? Questions { get; set; }
    }

    private class SubCategoryInfoModel
    {
        public int Id { get; set; }
        public string? Name { get; set; }
    }

    private class QuestionModel
    {
        public int Id { get; set; }
    }

    private class SubCategoryDetailModel
    {
        public int Id { get; set; }
        public string? Name { get; set; }
        public int QuestionCount { get; set; }
        public bool IsLocked { get; set; }
    }

    private class ProfileDataModel
    {
        public List<SubCategoryProgressModel>? PerSubCategory { get; set; }
    }

    private class SubCategoryProgressModel
    {
        public int SubCategoryId { get; set; }
        public int AccuracyPercent { get; set; }
    }
}

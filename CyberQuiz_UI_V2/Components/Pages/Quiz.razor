@page "/quiz/{SubCategoryId:int}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using CyberQuiz_Shared.DTOs
@using CyberQuiz_BLL.DTOs
@using CyberQuiz_UI_V2.Components.Shared
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Quiz</PageTitle>

<style>
    .quiz-container {
        min-height: 80vh;
    }

    .quiz-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(118, 75, 162, 0.15);
    }

    .quiz-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1.5rem;
    }

    .quiz-progress {
        height: 10px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.3);
    }

    .quiz-progress-bar {
        background: white;
        border-radius: 10px;
        transition: width 0.4s ease;
    }

    .question-text {
        font-size: 1.3rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 2rem;
    }

    .answer-option {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 1.2rem;
        margin-bottom: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        background: white;
    }

    .answer-option:hover {
        border-color: #764ba2;
        background: #f8f9fa;
        transform: translateX(5px);
    }

    .answer-option.selected {
        border-color: #764ba2;
        background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
        box-shadow: 0 4px 15px rgba(118, 75, 162, 0.2);
    }

    .answer-option input[type="radio"] {
        width: 20px;
        height: 20px;
        cursor: pointer;
    }

    .btn-next {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 12px 35px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-next:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(118, 75, 162, 0.4);
        color: white;
    }

    .btn-next:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .btn-chat {
        border: 2px solid #764ba2;
        color: #764ba2;
        padding: 12px 25px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        background: white;
    }

    .btn-chat:hover {
        background: #764ba2;
        color: white;
        transform: translateY(-3px);
    }

    .results-card {
        border: none;
        border-radius: 20px;
        background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
        box-shadow: 0 8px 25px rgba(118, 75, 162, 0.2);
    }

    .score-display {
        font-size: 4rem;
        font-weight: 900;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .btn-back {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 12px 35px;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-back:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(118, 75, 162, 0.4);
        color: white;
    }
</style>

<div class="container py-4 quiz-container">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Laddar quiz...</span>
            </div>
            <p class="mt-3 text-muted">Förbereder ditt quiz...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger border-0 shadow-sm" style="border-radius: 15px;">
            <strong>Fel:</strong> @errorMessage
            <div class="mt-3">
                <button class="btn btn-outline-secondary" @onclick="GoBack" style="border-radius: 25px;">
                    Tillbaka till start
                </button>
            </div>
        </div>
    }
    else if (questions.Any() && !showResults)
    {
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card quiz-card">
                    <div class="quiz-header">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h4 class="mb-0 fw-bold">Quiz</h4>
                            <span class="badge bg-white text-dark px-3 py-2" style="font-size: 0.9rem;">
                                Fråga @(currentQuestionIndex + 1) av @questions.Count
                            </span>
                        </div>
                        <div class="quiz-progress mt-3">
                            <div class="quiz-progress-bar" style="width: @progressPercent%"></div>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        @if (currentQuestionIndex < questions.Count)
                        {
                            var question = questions[currentQuestionIndex];

                            <div class="question-text">
                                @question.Text
                            </div>

                            <div class="mb-4">
                                @foreach (var option in question.Options ?? Enumerable.Empty<AnswerOptionDto>())
                                {
                                    <label class="answer-option @(selectedAnswerId == option.Id ? "selected" : "")">
                                        <div class="d-flex align-items-center">
                                            <input type="radio" 
                                                   name="answer" 
                                                   value="@option.Id" 
                                                   checked="@(selectedAnswerId == option.Id)"
                                                   @onchange="() => SelectAnswer(option.Id)" 
                                                   class="me-3" />
                                            <span style="flex: 1;">@option.Text</span>
                                        </div>
                                    </label>
                                }
                            </div>

                            <div class="d-flex gap-3 flex-wrap">
                                <button class="btn btn-next" 
                                        disabled="@(selectedAnswerId == null || isSubmitting)" 
                                        @onclick="SaveAnswerAndNext">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Skickar...</span>
                                    }
                                    else if (currentQuestionIndex < questions.Count - 1)
                                    {
                                        <span>Nästa fråga</span>
                                    }
                                    else
                                    {
                                        <span>Skicka quiz</span>
                                    }
                                </button>
                                <button class="btn btn-chat" @onclick="OpenChat">
                                    Fråga CyberChat
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (showResults && quizSummary != null)
    {
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="card results-card shadow-lg">
                    <div class="card-body text-center p-5">
                        <h3 class="mb-4 fw-bold" style="color: #764ba2;">Quiz slutfört!</h3>

                        <div class="score-display mb-3">
                            @quizSummary.CorrectAnswers / @quizSummary.TotalQuestions
                        </div>

                        <p class="lead mb-4" style="color: #555; font-size: 1.5rem; font-weight: 600;">
                            @((int)quizSummary.ScorePercentage)% rätt
                        </p>

                        @if (quizSummary.Passed)
                        {
                            <div class="alert alert-success border-0 mb-4" style="border-radius: 15px; background: #d4edda;">
                                <strong>Grattis!</strong> Du har låst upp nästa subkategori.
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning border-0 mb-4" style="border-radius: 15px; background: #fff3cd;">
                                Du behöver minst 80% för att låsa upp nästa subkategori.
                            </div>
                        }

                        <button class="btn btn-back" @onclick="GoBack">
                            Tillbaka till start
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- ChatPopup Component -->
<ChatPopup IsOpen="isChatOpen" 
           OnClose="CloseChat" 
           CurrentQuestion="GetCurrentQuestionContext()" />

@code {
    [Parameter]
    public int SubCategoryId { get; set; }

    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool showResults = false;
    private string? errorMessage;

    private List<QuestionDto> questions = new();
    private List<SubmitAnswerDto> userAnswers = new(); // Samlar alla svar lokalt
    private int currentQuestionIndex = 0;
    private int? selectedAnswerId;

    private QuizSummaryDto? quizSummary;

    // Chat state
    private bool isChatOpen = false;

    private int progressPercent => questions.Count > 0 ? (int)((currentQuestionIndex + 1) * 100.0 / questions.Count) : 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuizAsync();
    }

    private async Task LoadQuizAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var resp = await Http.GetAsync($"/api/quiz/start/{SubCategoryId}");
            if (resp.IsSuccessStatusCode)
            {
                questions = await resp.Content.ReadFromJsonAsync<List<QuestionDto>>() ?? new List<QuestionDto>();
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                errorMessage = "Subkategorin hittades inte.";
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Du måste vara inloggad för att starta ett quiz.";
            }
            else
            {
                errorMessage = $"Kunde inte hämta quiz (status: {resp.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte nå servern. ({ex.Message})";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectAnswer(int answerId)
    {
        selectedAnswerId = answerId;
    }

    private async Task SaveAnswerAndNext()
    {
        if (selectedAnswerId == null || currentQuestionIndex >= questions.Count)
            return;

        var question = questions[currentQuestionIndex];

        // Spara svaret lokalt
        userAnswers.Add(new SubmitAnswerDto
        {
            QuestionId = question.Id,
            SelectedAnswerOptionId = selectedAnswerId.Value
        });

        // Kolla om det är sista frågan INNAN vi ökar index
        bool isLastQuestion = (currentQuestionIndex == questions.Count - 1);

        if (isLastQuestion)
        {
            // Sista frågan → submitta direkt (await för att vänta)
            isSubmitting = true;
            await SubmitQuizAsync();
            return; // Stoppa här, visa inte nästa fråga
        }

        // Inte sista frågan → gå till nästa
        currentQuestionIndex++;
        selectedAnswerId = null;
    }

    private async Task SubmitQuizAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var submitDto = new SubmitQuizDto
            {
                SubCategoryId = SubCategoryId,
                Answers = userAnswers
            };

            var resp = await Http.PostAsJsonAsync("/api/quiz/submit", submitDto);
            if (resp.IsSuccessStatusCode)
            {
                quizSummary = await resp.Content.ReadFromJsonAsync<QuizSummaryDto>();
                showResults = true;
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Du måste vara inloggad.";
            }
            else
            {
                errorMessage = $"Kunde inte skicka quiz (status: {resp.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte nå servern. ({ex.Message})";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/start");
    }

    // Chat methods
    private void OpenChat()
    {
        isChatOpen = true;
    }

    private void CloseChat()
    {
        isChatOpen = false;
    }

    private QuestionContext? GetCurrentQuestionContext()
    {
        if (currentQuestionIndex >= questions.Count)
            return null;

        var question = questions[currentQuestionIndex];
        return new QuestionContext
        {
            QuestionId = question.Id,
            QuestionText = question.Text,
            AnswerOptions = question.Options?.Select(o => o.Text).ToList() ?? new List<string>()
        };
    }
}

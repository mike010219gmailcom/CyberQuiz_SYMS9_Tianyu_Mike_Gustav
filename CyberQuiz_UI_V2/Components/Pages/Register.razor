@page "/register"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using CyberQuiz_UI_V2.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject TokenService TokenService

<PageTitle>Registrera</PageTitle>

<style>
    .register-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        padding: 40px 0;
    }

    .register-card {
        border: none;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .register-header {
        font-size: 2rem;
        font-weight: 900;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 2rem;
    }

    .form-control-custom {
        border-radius: 10px;
        padding: 12px 16px;
        border: 2px solid #e9ecef;
        transition: all 0.3s ease;
    }

    .form-control-custom:focus {
        border-color: #764ba2;
        box-shadow: 0 0 0 3px rgba(118, 75, 162, 0.1);
        outline: none;
    }

    .btn-register {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 12px 40px;
        border-radius: 25px;
        font-weight: 600;
        width: 100%;
        transition: all 0.3s ease;
    }

    .btn-register:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(118, 75, 162, 0.4);
        color: white;
    }

    .btn-register:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }

    .btn-login-link {
        color: #764ba2;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-login-link:hover {
        color: #667eea;
        text-decoration: underline;
    }

    .form-label-custom {
        font-weight: 600;
        color: #555;
        margin-bottom: 0.5rem;
    }

    .alert-custom {
        border: none;
        border-radius: 10px;
    }
</style>

<div class="register-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card register-card">
                    <div class="card-body p-5">
                        <h3 class="register-header text-center">Registrera konto</h3>

                        <EditForm Model="registerModel" OnValidSubmit="HandleValidSubmit">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="alert alert-warning alert-custom" />

                            <div class="mb-4">
                                <label class="form-label form-label-custom">Användarnamn / E-post</label>
                                <InputText class="form-control form-control-custom" @bind-Value="registerModel.Username" placeholder="Ditt användarnamn" />
                                <ValidationMessage For="() => registerModel.Username" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label form-label-custom">Lösenord</label>
                                <InputText class="form-control form-control-custom" type="password" @bind-Value="registerModel.Password" placeholder="••••••••" />
                                <ValidationMessage For="() => registerModel.Password" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label form-label-custom">Bekräfta lösenord</label>
                                <InputText class="form-control form-control-custom" type="password" @bind-Value="registerModel.ConfirmPassword" placeholder="••••••••" />
                                <ValidationMessage For="() => registerModel.ConfirmPassword" class="text-danger small mt-1" />
                            </div>

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger alert-custom mb-4" role="alert">
                                    @errorMessage
                                </div>
                            }

                            <button type="submit" class="btn btn-register mb-3" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Registrerar...</span>
                                }
                                else
                                {
                                    <span>Registrera</span>
                                }
                            </button>

                            <div class="text-center">
                                <span class="text-muted">Har du redan ett konto? </span>
                                <button type="button" class="btn btn-link btn-login-link p-0" @onclick="GoToLogin">
                                    Logga in här
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private bool isSubmitting = false;


    private async Task HandleValidSubmit()
    {
        errorMessage = null;

        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Lösenorden matchar inte.";
            return;
        }

        isSubmitting = true;

        // Skicka registreringsdata till API:et
        try
        {
            var user = new { Username = registerModel.Username, Password = registerModel.Password };
            var response = await Http.PostAsJsonAsync("/api/auth/register", user);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RegisterResponse>();
                if (result != null && !string.IsNullOrEmpty(result.Token))
                {
                    TokenService.SetToken(result.Token);
                    Navigation.NavigateTo("/start");
                }
                else
                {
                    errorMessage = "Kunde inte hämta token från servern.";
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                // Läsa error felmeddelande 
                try
                {
                    var errors = await response.Content.ReadFromJsonAsync<object?>();
                    errorMessage = errors?.ToString() ?? "Fel vid registrering.";
                }
                catch
                {
                    errorMessage = "Fel vid registrering.";
                }
            }
            else
            {
                errorMessage = "Serverfel vid registrering.";
            }
        }
        catch
        {
            errorMessage = "Kunde inte nå servern.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // Navigera tillbaka till login-sidan
    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    // Modell för registreringsformuläret med validering
    private class RegisterModel
    {
        [Required(ErrorMessage = "Användarnamn krävs")]
        public string? Username { get; set; }

        [Required(ErrorMessage = "Lösenord krävs")]
        [MinLength(6, ErrorMessage = "Lösenord måste ha minst 6 tecken")]
        public string? Password { get; set; }

        [Required(ErrorMessage = "Bekräfta lösenord")]
        public string? ConfirmPassword { get; set; }
    }

    private class RegisterResponse
    {
        public string Token { get; set; } = "";
    }
}

@page "/register"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Registrera</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h3 class="card-title mb-3">Registrera konto</h3>

                    <EditForm Model="registerModel" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3 text-start">
                            <label class="form-label">Användarnamn / E-post</label>
                            <InputText class="form-control" @bind-Value="registerModel.Username" />
                            <ValidationMessage For="() => registerModel.Username" />
                        </div>

                        <div class="mb-3 text-start">
                            <label class="form-label">Lösenord</label>
                            <InputText class="form-control" type="password" @bind-Value="registerModel.Password" />
                            <ValidationMessage For="() => registerModel.Password" />
                        </div>

                        <div class="mb-3 text-start">
                            <label class="form-label">Bekräfta lösenord</label>
                            <InputText class="form-control" type="password" @bind-Value="registerModel.ConfirmPassword" />
                            <ValidationMessage For="() => registerModel.ConfirmPassword" />
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger" role="alert">@errorMessage</div>
                        }

                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> <span>Registrerar...</span>
                                
                            }
                            else
                            {
                                <span>Registrera</span>
                            }
                        </button>

                        <button type="button" class="btn btn-link" @onclick="GoToLogin">Tillbaka till inloggning</button>
                    </EditForm>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string? errorMessage;
    private bool isSubmitting = false;

    
    private async Task HandleValidSubmit()
    {
        errorMessage = null;

        if (registerModel.Password != registerModel.ConfirmPassword)
        {
            errorMessage = "Lösenorden matchar inte.";
            return;
        }

        isSubmitting = true;

        // Skicka registreringsdata till API:et
        try
        {
            var user = new { Username = registerModel.Username, Password = registerModel.Password };
            var response = await Http.PostAsJsonAsync("/api/auth/register", user);
            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/start");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                // Läsa error felmeddelande 
                try
                {
                    var errors = await response.Content.ReadFromJsonAsync<object?>();
                    errorMessage = errors?.ToString() ?? "Fel vid registrering.";
                }
                catch
                {
                    errorMessage = "Fel vid registrering.";
                }
            }
            else
            {
                errorMessage = "Serverfel vid registrering.";
            }
        }
        catch
        {
            errorMessage = "Kunde inte nå servern.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // Navigera tillbaka till login-sidan
    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    // Modell för registreringsformuläret med validering
    private class RegisterModel
    {
        [Required(ErrorMessage = "Användarnamn krävs")]
        public string? Username { get; set; }

        [Required(ErrorMessage = "Lösenord krävs")]
        [MinLength(6, ErrorMessage = "Lösenord måste ha minst 6 tecken")]
        public string? Password { get; set; }

        [Required(ErrorMessage = "Bekräfta lösenord")]
        public string? ConfirmPassword { get; set; }
    }
}

@page "/profile"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using CyberQuiz_UI_V2.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject TokenService TokenService

<PageTitle>Profil</PageTitle>

<style>
    .profile-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
        border-radius: 15px;
        color: white;
        margin-bottom: 2rem;
        box-shadow: 0 5px 20px rgba(118, 75, 162, 0.3);
    }

    .stats-card {
        border: none;
        border-radius: 15px;
        background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
        transition: all 0.3s ease;
    }

    .stats-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(118, 75, 162, 0.3);
    }

    .progress-card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
    }

    .settings-card {
        border: none;
        border-radius: 15px;
        transition: all 0.3s ease;
    }

    .settings-card:hover {
        box-shadow: 0 10px 25px rgba(118, 75, 162, 0.2);
    }

    .custom-progress {
        height: 25px;
        border-radius: 15px;
        background: #e9ecef;
    }

    .custom-progress-bar {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px;
        transition: width 0.6s ease;
    }

    .btn-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        transition: all 0.3s ease;
    }

    .btn-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(118, 75, 162, 0.4);
        color: white;
    }

    .btn-back {
        background: white;
        color: #764ba2;
        border: 2px solid #764ba2;
        padding: 8px 20px;
        border-radius: 25px;
        transition: all 0.3s ease;
    }

    .btn-back:hover {
        background: #764ba2;
        color: white;
        transform: translateX(-5px);
    }

    .accuracy-badge {
        font-size: 4rem;
        font-weight: 900;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
</style>

<div class="container py-4">
    <!-- Back Button -->
    <div class="mb-4">
        <a href="/start" class="btn btn-back text-decoration-none">
            ← Tillbaka till start
        </a>
    </div>

    <!-- Profile Header -->
    <div class="profile-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1 fw-bold">👤 Din Profil</h2>
                <p class="mb-0 opacity-75">Progression och kontoinställningar</p>
            </div>
            <div class="text-end">
                @if (!string.IsNullOrEmpty(userName))
                {
                    <div class="badge px-3 py-2" style="background: white; color: #764ba2; font-size: 1rem;">
                        @userName
                    </div>
                }
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Laddar profil...</span>
            </div>
            <p class="mt-3 text-muted">Laddar din profil...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-warning border-0 shadow-sm" style="border-radius: 15px;">
            <strong>⚠️ Info:</strong> @errorMessage
        </div>
    }
    else if (profileData != null)
    {
        <!-- Total Progression -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card stats-card shadow text-center">
                    <div class="card-body py-5">
                        <h3 class="mb-4" style="color: #764ba2;">Din totala progression</h3>
                        <div class="accuracy-badge mb-3">
                            @profileData.TotalAccuracyPercent%
                        </div>
                        <p class="lead mb-4 text-muted">
                            @profileData.TotalCorrect av @profileData.TotalAnswers frågor rätt
                        </p>
                        <div class="custom-progress">
                            <div class="custom-progress-bar" 
                                 role="progressbar" 
                                 style="width: @profileData.TotalAccuracyPercent%">
                                <span class="px-3 fw-bold">@profileData.TotalAccuracyPercent%</span>
                            </div>
                        </div>
                        @if (profileData.TotalAccuracyPercent >= 80)
                        {
                            <div class="alert alert-success border-0 mt-4 mb-0" style="border-radius: 15px;">
                                <strong> Grattis!</strong> Du har nått 80%-målet.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Progression per Subkategori -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card progress-card shadow">
                    <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 1.5rem;">
                        <h5 class="mb-0 fw-bold"> Progression per subkategori</h5>
                    </div>
                    <div class="card-body p-4">
                        @if (profileData.PerSubCategory?.Any() == true)
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead style="background: #f8f9fa;">
                                        <tr>
                                            <th style="padding: 1rem;">Subkategori</th>
                                            <th style="width: 50%; padding: 1rem;">Progression</th>
                                            <th class="text-end" style="padding: 1rem;">Accuracy</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var sub in profileData.PerSubCategory)
                                        {
                                            <tr style="transition: all 0.3s ease;">
                                                <td style="padding: 1rem;">
                                                    <strong style="color: #764ba2;"> @sub.SubCategoryName</strong>
                                                </td>
                                                <td style="padding: 1rem;">
                                                    <div class="custom-progress">
                                                        <div class="custom-progress-bar" 
                                                             role="progressbar" 
                                                             style="width: @sub.AccuracyPercent%">
                                                            <span class="px-3 fw-bold">@sub.AccuracyPercent%</span>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-end" style="padding: 1rem;">
                                                    <span class="badge px-3 py-2" 
                                                          style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); font-size: 1rem;">
                                                        @sub.AccuracyPercent%
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info border-0 mb-0" style="border-radius: 15px;">
                                📚 Du har inte svarat på några frågor än. <a href="/start" class="alert-link fw-bold">Gå till Start</a> för att börja!
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Settings Cards -->
        <div class="row mb-4">
            <!-- Ändra E-post -->
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="card settings-card shadow">
                    <div class="card-header" style="background: #f8f9fa; border-bottom: 2px solid #e1bee7; padding: 1.5rem;">
                        <h5 class="mb-0 fw-bold" style="color: #764ba2;">Ändra e-post</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ny e-post</label>
                            <input type="email" class="form-control" @bind="newEmail" placeholder="exempel@mail.com" style="border-radius: 10px; padding: 12px;" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Bekräfta e-post</label>
                            <input type="email" class="form-control" @bind="confirmEmail" placeholder="exempel@mail.com" style="border-radius: 10px; padding: 12px;" />
                        </div>
                        <button class="btn btn-custom w-100" @onclick="ChangeEmail" disabled="@isChangingEmail">
                            @if (isChangingEmail)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Uppdaterar...</span>
                            }
                            else
                            {
                                <span>Uppdatera e-post</span>
                            }
                        </button>
                        @if (!string.IsNullOrEmpty(emailMessage))
                        {
                            <div class="alert @(emailMessageIsError ? "alert-danger" : "alert-success") border-0 mt-3 mb-0" style="border-radius: 10px;">
                                @emailMessage
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Ändra Lösenord -->
            <div class="col-lg-6">
                <div class="card settings-card shadow">
                    <div class="card-header" style="background: #f8f9fa; border-bottom: 2px solid #e1bee7; padding: 1.5rem;">
                        <h5 class="mb-0 fw-bold" style="color: #764ba2;">Ändra lösenord</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nuvarande lösenord</label>
                            <input type="password" class="form-control" @bind="currentPassword" placeholder="••••••••" style="border-radius: 10px; padding: 12px;" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nytt lösenord</label>
                            <input type="password" class="form-control" @bind="newPassword" placeholder="••••••••" style="border-radius: 10px; padding: 12px;" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Bekräfta nytt lösenord</label>
                            <input type="password" class="form-control" @bind="confirmPassword" placeholder="••••••••" style="border-radius: 10px; padding: 12px;" />
                        </div>
                        <button class="btn btn-custom w-100" @onclick="ChangePassword" disabled="@isChangingPassword">
                            @if (isChangingPassword)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Uppdaterar...</span>
                            }
                            else
                            {
                                <span>Uppdatera lösenord</span>
                            }
                        </button>
                        @if (!string.IsNullOrEmpty(passwordMessage))
                        {
                            <div class="alert @(passwordMessageIsError ? "alert-danger" : "alert-success") border-0 mt-3 mb-0" style="border-radius: 10px;">
                                @passwordMessage
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private ProfileDataModel? profileData;
    private string? userName;

    // Formulär-fält
    private string? newEmail;
    private string? confirmEmail;
    private string? emailMessage;
    private bool emailMessageIsError;
    private bool isChangingEmail;

    private string? currentPassword;
    private string? newPassword;
    private string? confirmPassword;
    private string? passwordMessage;
    private bool passwordMessageIsError;
    private bool isChangingPassword;

    protected override async Task OnInitializedAsync()
    {
        TrySetUserName();
        await LoadProfileAsync();
    }

    private void TrySetUserName()
    {
        try
        {
            var token = TokenService.GetToken();
            if (string.IsNullOrEmpty(token))
                return;

            var parts = token.Split('.');
            if (parts.Length != 3)
                return;

            var payload = parts[1];
            var base64 = payload.PadRight(payload.Length + (4 - payload.Length % 4) % 4, '=')
                                .Replace('-', '+').Replace('_', '/');

            var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(base64));

            var searchPatterns = new[] 
            { 
                "\"http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name\":\"",
                "\"name\":\"",
                "\"unique_name\":\""
            };

            foreach (var pattern in searchPatterns)
            {
                if (json.Contains(pattern))
                {
                    var nameStart = json.IndexOf(pattern) + pattern.Length;
                    var nameEnd = json.IndexOf("\"", nameStart);
                    if (nameEnd > nameStart)
                    {
                        userName = json.Substring(nameStart, nameEnd - nameStart);
                        return;
                    }
                }
            }
        }
        catch
        {
            // Ignorera fel
        }
    }

    private async Task LoadProfileAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var resp = await Http.GetAsync("/api/profile");
            if (resp.IsSuccessStatusCode)
            {
                profileData = await resp.Content.ReadFromJsonAsync<ProfileDataModel>();
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                errorMessage = "Profil-endpoint saknas";
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Du måste vara inloggad för att se din profil.";
            }
            else
            {
                errorMessage = $"Kunde inte hämta profil (status: {resp.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte nå servern. ({ex.Message})";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangeEmail()
    {
        emailMessage = null;
        emailMessageIsError = false;

        // Validering
        if (string.IsNullOrWhiteSpace(newEmail))
        {
            emailMessage = "E-post får inte vara tom";
            emailMessageIsError = true;
            return;
        }

        if (newEmail != confirmEmail)
        {
            emailMessage = "E-postadresserna matchar inte";
            emailMessageIsError = true;
            return;
        }

        isChangingEmail = true;

        try
        {
            var request = new { NewEmail = newEmail, ConfirmEmail = confirmEmail };
            var response = await Http.PostAsJsonAsync("/api/profile/change-email", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse>();
                emailMessage = result?.Message ?? "E-post uppdaterad!";
                emailMessageIsError = false;

                // Rensa fälten
                newEmail = null;
                confirmEmail = null;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ApiResponse>();
                emailMessage = error?.Message ?? "Kunde inte uppdatera e-post";
                emailMessageIsError = true;
            }
        }
        catch (Exception ex)
        {
            emailMessage = $"Fel: {ex.Message}";
            emailMessageIsError = true;
        }
        finally
        {
            isChangingEmail = false;
        }
    }

    private async Task ChangePassword()
    {
        passwordMessage = null;
        passwordMessageIsError = false;

        // Validering
        if (string.IsNullOrWhiteSpace(currentPassword))
        {
            passwordMessage = "Nuvarande lösenord krävs";
            passwordMessageIsError = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(newPassword))
        {
            passwordMessage = "Nytt lösenord får inte vara tomt";
            passwordMessageIsError = true;
            return;
        }

        if (newPassword != confirmPassword)
        {
            passwordMessage = "Lösenorden matchar inte";
            passwordMessageIsError = true;
            return;
        }

        if (newPassword.Length < 6)
        {
            passwordMessage = "Lösenordet måste vara minst 6 tecken långt";
            passwordMessageIsError = true;
            return;
        }

        isChangingPassword = true;

        try
        {
            var request = new 
            { 
                CurrentPassword = currentPassword, 
                NewPassword = newPassword, 
                ConfirmPassword = confirmPassword 
            };
            var response = await Http.PostAsJsonAsync("/api/profile/change-password", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse>();
                passwordMessage = result?.Message ?? "Lösenord uppdaterat!";
                passwordMessageIsError = false;

                // Rensa fälten
                currentPassword = null;
                newPassword = null;
                confirmPassword = null;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ApiResponse>();
                passwordMessage = error?.Message ?? "Kunde inte uppdatera lösenord";
                passwordMessageIsError = true;
            }
        }
        catch (Exception ex)
        {
            passwordMessage = $"Fel: {ex.Message}";
            passwordMessageIsError = true;
        }
        finally
        {
            isChangingPassword = false;
        }
    }

    private string GetAccuracyColorClass(int percent)
    {
        if (percent >= 80) return "text-success";
        if (percent >= 50) return "text-warning";
        return "text-danger";
    }

    private string GetProgressBarClass(int percent)
    {
        if (percent >= 80) return "bg-success";
        if (percent >= 50) return "bg-warning";
        return "bg-danger";
    }

    private string GetBadgeClass(int percent)
    {
        if (percent >= 80) return "bg-success";
        if (percent >= 50) return "bg-warning";
        return "bg-danger";
    }

    private class ProfileDataModel
    {
        public int TotalAnswers { get; set; }
        public int TotalCorrect { get; set; }
        public double TotalAccuracy { get; set; }
        public int TotalAccuracyPercent { get; set; }
        public List<SubCategoryProgressModel>? PerSubCategory { get; set; }
    }

    private class SubCategoryProgressModel
    {
        public int SubCategoryId { get; set; }
        public string? SubCategoryName { get; set; }
        public double Accuracy { get; set; }
        public int AccuracyPercent { get; set; }
    }

    private class ApiResponse
    {
        public string Message { get; set; } = "";
    }
}

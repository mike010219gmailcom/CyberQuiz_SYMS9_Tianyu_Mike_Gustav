@page "/start"
@using System.Net.Http.Json
@using CyberQuiz_UI_V2.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject TokenService TokenService

<PageTitle>Start</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Start</h2>
            <small class="text-muted">Översikt över kategorier och progression</small>
        </div>
        <div class="text-end">
            @if (!string.IsNullOrEmpty(userName))
            {
                <a href="/profile" class="text-decoration-none">
                    <div class="fw-semibold text-primary" style="cursor: pointer;">👤 @userName</div>
                </a>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Laddar...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-warning">
            <strong>Info:</strong> @errorMessage
        </div>
    }
    else
    {
        @if (categories?.Any() != true)
        {
            <div class="alert alert-info">Inga kategorier att visa. Backend-endpoint saknas eller returnerar tomt resultat.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var cat in categories)
                {
                    <div class="col-12">
                        <div class="card shadow-sm" style="background-color: #f3e5f5;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="card-title mb-0">@cat.Name</h5>
                                    <small class="text-muted">@(cat.SubCategories?.Count ?? 0) subkategorier</small>
                                </div>

                                @if (cat.SubCategories?.Any() == true)
                                {
                                    <ul class="list-group list-group-flush">
                                        @foreach (var sc in cat.SubCategories)
                                        {
                                            <li class="list-group-item @(sc.IsLocked ? "bg-light" : "")">
                                                <a href="/subcategory/@sc.Id" class="text-decoration-none @(sc.IsLocked ? "pe-none" : "")" style="display: block;">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div>
                                                            @if (sc.IsLocked)
                                                            {
                                                                <span class="badge bg-secondary me-2">🔒</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-success me-2">🔓</span>
                                                            }
                                                            <strong class="@(sc.IsLocked ? "text-muted" : "text-primary")">@sc.Name</strong>
                                                            <div class="small text-muted">@sc.QuestionCount frågor</div>
                                                        </div>
                                                        @if (!sc.IsLocked)
                                                        {
                                                            <span class="text-primary">→</span>
                                                        }
                                                    </div>
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted mb-0">Inga subkategorier tillgängliga.</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private List<CategoryModel>? categories;
    private string? userName;

	protected override async Task OnInitializedAsync()
	{
		// Vänta tills token finns (max 5 sekunder)
		// Detta hanterar race condition när Start laddar samtidigt som Login sparar token
		for (int i = 0; i < 50 && string.IsNullOrEmpty(TokenService.GetToken()); i++)
		{
			await Task.Delay(100);
		}

		TrySetUserName();
		await LoadCategoriesAsync();
	}

	private void TrySetUserName()
	{
		try
		{
			var token = TokenService.GetToken();
			if (string.IsNullOrEmpty(token))
				return;

			// Dekoda JWT payload
			var parts = token.Split('.');
			if (parts.Length != 3)
				return;

			// Base64Url dekodning av payload
			var payload = parts[1];
			var base64 = payload.PadRight(payload.Length + (4 - payload.Length % 4) % 4, '=')
								.Replace('-', '+').Replace('_', '/');

			var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(base64));

			// JWT claims använder långa namespaces - prova flera varianter
			var searchPatterns = new[] 
			{ 
				"\"http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name\":\"",
				"\"name\":\"",
				"\"unique_name\":\""
			};

			foreach (var pattern in searchPatterns)
			{
				if (json.Contains(pattern))
				{
					var nameStart = json.IndexOf(pattern) + pattern.Length;
					var nameEnd = json.IndexOf("\"", nameStart);
					if (nameEnd > nameStart)
					{
						userName = json.Substring(nameStart, nameEnd - nameStart);
						return;
					}
				}
			}
		}
		catch
		{
			// Ignorera fel - username är valfritt
		}
	}

    private async Task LoadCategoriesAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var resp = await Http.GetAsync("/api/categories");
            if (resp.IsSuccessStatusCode)
            {
                var data = await resp.Content.ReadFromJsonAsync<List<CategoryModel>>();
                categories = data ?? new List<CategoryModel>();
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                errorMessage = "API-endpoint /api/categories saknas";
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Du måste vara inloggad för att se kategorier.";
            }
            else
            {
                errorMessage = $"Kunde inte hämta kategorier från servern (status: {resp.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte nå servern. Kontrollera att API körs. ({ex.Message})";
        }
        finally
        {
            isLoading = false;
        }
    }

	private class CategoryModel
	{
		public int Id { get; set; }
		public string? Name { get; set; }
		public List<SubCategoryModel>? SubCategories { get; set; }
	}

	private class SubCategoryModel
	{
		public int Id { get; set; }
		public string? Name { get; set; }
		public int Order { get; set; }
		public int QuestionCount { get; set; }
		public bool IsLocked { get; set; }
	}
}

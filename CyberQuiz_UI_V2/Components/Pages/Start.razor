@page "/start"
@using System.Net.Http.Json
@using CyberQuiz_UI_V2.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject TokenService TokenService

<PageTitle>Start</PageTitle>

<style>
    .start-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
        border-radius: 15px;
        color: white;
        margin-bottom: 2rem;
        box-shadow: 0 5px 20px rgba(118, 75, 162, 0.3);
    }

    .category-card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.3s ease;
        background: linear-gradient(135deg, #f3e5f5 0%, #e1bee7 100%);
    }

    .category-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(118, 75, 162, 0.3);
    }

    .subcategory-item {
        border: none;
        border-radius: 10px;
        margin-bottom: 0.5rem;
        transition: all 0.3s ease;
        background: white;
    }

    .subcategory-item:hover:not(.locked) {
        transform: translateX(10px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.2);
    }

    .subcategory-item.locked {
        opacity: 0.6;
    }

    .badge-icon {
        font-size: 1.2rem;
    }

    .profile-link {
        background: white;
        padding: 0.5rem 1rem;
        border-radius: 25px;
        transition: all 0.3s ease;
        box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
    }

    .profile-link:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(118, 75, 162, 0.3);
    }
</style>

<div class="container py-4">
    <!-- Modern Header with Gradient -->
    <div class="start-header">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1 fw-bold">
                    Välkommen@(!string.IsNullOrEmpty(userName) ? $" {userName}" : "")!
                </h2>
                <p class="mb-0 opacity-75">Välj en kategori för att börja</p>
            </div>
            <div>
                @if (!string.IsNullOrEmpty(userName))
                {
                    <a href="/profile" class="text-decoration-none">
                        <div class="profile-link">
                            <span class="fw-semibold" style="color: #764ba2;">👤 @userName</span>
                        </div>
                    </a>
                }
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Laddar...</span>
            </div>
            <p class="mt-3 text-muted">Laddar dina kategorier...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-warning border-0 shadow-sm" style="border-radius: 15px;">
            <strong>⚠️ Info:</strong> @errorMessage
        </div>
    }
    else
    {
        @if (categories?.Any() != true)
        {
            <div class="alert alert-info border-0 shadow-sm" style="border-radius: 15px;">
                📚 Inga kategorier att visa. Backend-endpoint saknas eller returnerar tomt resultat.
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var cat in categories)
                {
                    <div class="col-12">
                        <div class="card category-card shadow">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h4 class="card-title mb-0 fw-bold" style="color: #764ba2;">
                                        📂 @cat.Name
                                    </h4>
                                    <span class="badge rounded-pill px-3 py-2" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); font-size: 0.9rem;">
                                        @(cat.SubCategories?.Count ?? 0) subkategorier
                                    </span>
                                </div>

                                @if (cat.SubCategories?.Any() == true)
                                {
                                    <div class="d-flex flex-column gap-2">
                                        @foreach (var sc in cat.SubCategories)
                                        {
                                            <div class="subcategory-item @(sc.IsLocked ? "locked" : "") p-3">
                                                <a href="/subcategory/@sc.Id?name=@Uri.EscapeDataString(sc.Name)" 
                                                   class="text-decoration-none @(sc.IsLocked ? "pe-none" : "")" 
                                                   style="display: block;">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div class="d-flex align-items-center gap-3">
                                                            @if (sc.IsLocked)
                                                            {
                                                                <span class="badge-icon">🔒</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge-icon">🔓</span>
                                                            }
                                                            <div>
                                                                <strong class="@(sc.IsLocked ? "text-muted" : "")" style="@(sc.IsLocked ? "" : "color: #764ba2;")">
                                                                    @sc.Name
                                                                </strong>
                                                                <div class="small text-muted">
                                                                    📝 @sc.QuestionCount frågor
                                                                </div>
                                                            </div>
                                                        </div>
                                                        @if (!sc.IsLocked)
                                                        {
                                                            <span style="color: #667eea; font-size: 1.5rem; font-weight: bold;">→</span>
                                                        }
                                                    </div>
                                                </a>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted mb-0">📭 Inga subkategorier tillgängliga.</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private List<CategoryModel>? categories;
    private string? userName;

	protected override async Task OnInitializedAsync()
	{
		// Vänta tills token finns (max 5 sekunder)
		// Detta hanterar race condition när Start laddar samtidigt som Login sparar token
		for (int i = 0; i < 50 && string.IsNullOrEmpty(TokenService.GetToken()); i++)
		{
			await Task.Delay(100);
		}

		TrySetUserName();
		await LoadCategoriesAsync();
	}

	private void TrySetUserName()
	{
		try
		{
			var token = TokenService.GetToken();
			if (string.IsNullOrEmpty(token))
				return;

			// Dekoda JWT payload
			var parts = token.Split('.');
			if (parts.Length != 3)
				return;

			// Base64Url dekodning av payload
			var payload = parts[1];
			var base64 = payload.PadRight(payload.Length + (4 - payload.Length % 4) % 4, '=')
								.Replace('-', '+').Replace('_', '/');

			var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(base64));

			// JWT claims använder långa namespaces - prova flera varianter
			var searchPatterns = new[] 
			{ 
				"\"http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name\":\"",
				"\"name\":\"",
				"\"unique_name\":\""
			};

			foreach (var pattern in searchPatterns)
			{
				if (json.Contains(pattern))
				{
					var nameStart = json.IndexOf(pattern) + pattern.Length;
					var nameEnd = json.IndexOf("\"", nameStart);
					if (nameEnd > nameStart)
					{
						userName = json.Substring(nameStart, nameEnd - nameStart);
						return;
					}
				}
			}
		}
		catch
		{
			// Ignorera fel - username är valfritt
		}
	}

    private async Task LoadCategoriesAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var resp = await Http.GetAsync("/api/categories");
            if (resp.IsSuccessStatusCode)
            {
                var data = await resp.Content.ReadFromJsonAsync<List<CategoryModel>>();
                categories = data ?? new List<CategoryModel>();
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                errorMessage = "API-endpoint /api/categories saknas";
            }
            else if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Du måste vara inloggad för att se kategorier.";
            }
            else
            {
                errorMessage = $"Kunde inte hämta kategorier från servern (status: {resp.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte nå servern. Kontrollera att API körs. ({ex.Message})";
        }
        finally
        {
            isLoading = false;
        }
    }

	private class CategoryModel
	{
		public int Id { get; set; }
		public string? Name { get; set; }
		public List<SubCategoryModel>? SubCategories { get; set; }
	}

	private class SubCategoryModel
	{
		public int Id { get; set; }
		public string? Name { get; set; }
		public int Order { get; set; }
		public int QuestionCount { get; set; }
		public bool IsLocked { get; set; }
	}
}

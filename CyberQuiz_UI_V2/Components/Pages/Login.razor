@page "/login"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using CyberQuiz_UI_V2.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject TokenService TokenService

<PageTitle>Logga in</PageTitle>

<style>
    .login-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        padding: 40px 0;
    }

    .login-card {
        border: none;
        border-radius: 20px;
        background: white;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .login-header {
        font-size: 2rem;
        font-weight: 900;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 2rem;
    }

    .form-control-custom {
        border-radius: 10px;
        padding: 12px 16px;
        border: 2px solid #e9ecef;
        transition: all 0.3s ease;
    }

    .form-control-custom:focus {
        border-color: #764ba2;
        box-shadow: 0 0 0 3px rgba(118, 75, 162, 0.1);
        outline: none;
    }

    .btn-login {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 12px 40px;
        border-radius: 25px;
        font-weight: 600;
        width: 100%;
        transition: all 0.3s ease;
    }

    .btn-login:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(118, 75, 162, 0.4);
        color: white;
    }

    .btn-register-link {
        color: #764ba2;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-register-link:hover {
        color: #667eea;
        text-decoration: underline;
    }

    .form-label-custom {
        font-weight: 600;
        color: #555;
        margin-bottom: 0.5rem;
    }

    .alert-custom {
        border: none;
        border-radius: 10px;
    }
</style>

<div class="login-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <div class="card login-card">
                    <div class="card-body p-5">
                        <h3 class="login-header text-center">Logga in</h3>

                        <EditForm Model="loginModel" OnValidSubmit="HandleValidSubmit">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="alert alert-warning alert-custom" />

                            <div class="mb-4">
                                <label class="form-label form-label-custom">Användarnamn</label>
                                <InputText class="form-control form-control-custom" @bind-Value="loginModel.Username" />
                                <ValidationMessage For="() => loginModel.Username" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label form-label-custom">Lösenord</label>
                                <InputText class="form-control form-control-custom" type="password" @bind-Value="loginModel.Password"/>
                                <ValidationMessage For="() => loginModel.Password" class="text-danger small mt-1" />
                            </div>

                            <div class="mb-4 form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="loginModel.RememberMe" id="rememberMe" />
                                <label class="form-check-label" for="rememberMe">Kom ihåg mig</label>
                            </div>

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger alert-custom mb-4" role="alert">
                                    @errorMessage
                                </div>
                            }

                            <button type="submit" class="btn btn-login mb-3">
                                Logga in
                            </button>

                            <div class="text-center">
                                <span class="text-muted">Har du inget konto? </span>
                                <button type="button" class="btn btn-link btn-register-link p-0" @onclick="GoToRegister">
                                    Registrera här
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string? errorMessage;

    private async Task HandleValidSubmit()
    {
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/login", loginModel);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
                if (result != null && !string.IsNullOrEmpty(result.Token))
                {
                    TokenService.SetToken(result.Token);

                    // Vänta så token hinner propagera
                    await Task.Delay(200);

                    Navigation.NavigateTo("/start");
                }
                else
                {
                    errorMessage = "Kunde inte hämta token från servern.";
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Fel användarnamn eller lösenord.";
            }
            else
            {
                errorMessage = "Serverfel vid inloggning.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Kunde inte nå servern: {ex.Message}";
        }
    }

    private void GoToRegister()
    {
        Navigation.NavigateTo("/register");
    }

    private class LoginModel
    {
        [Required(ErrorMessage = "Användarnamn krävs")]
        public string? Username { get; set; }

        [Required(ErrorMessage = "Lösenord krävs")]
        public string? Password { get; set; }

        public bool RememberMe { get; set; }
    }

    private class LoginResponse
    {
        public string Token { get; set; } = "";
    }
}

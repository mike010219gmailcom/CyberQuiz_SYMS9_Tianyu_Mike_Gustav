{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Swagger": {
    "Enabled": true,
    "RoutePrefix": "swagger",
    "EndpointUrl": "/swagger/v1/swagger.json",
    "Name": "CyberQuiz API v1"
  },
  "JwtSettings": {
    "SecretKey": "CyberQuiz-Super-Secret-Key-Min-32-Chars-Long!",
